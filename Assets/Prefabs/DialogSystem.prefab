  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7b9f966cbd6145439b4e401d06d75d46, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogLines:
  - lines:
    - Oh mighty Spirit of the Forest, hear me!
    - Come and save our home!
    - 'Note: use F to interact'
  - lines:
    - Please save our home!
    - Stop the fire ahead!
  - lines:
    - The only way to get across is from above...
    - 'Note: Press 1-2 to switch form'
  - lines:
    - Thank you for stopping him, but more of them will come
    - There is a facility ahead that you should destroy before it's too late!
    - Follow me!
  - lines:
    - A keycard
    - may be it will open the shutted door above?
  - lines: []
