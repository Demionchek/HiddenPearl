--- !u!114 &7355081867131012548
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 269190993439955207}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7b9f966cbd6145439b4e401d06d75d46, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogLines:
  - dialogueLines:
    - text: Hey you! Who let you in here?
      onLineStart:
        m_PersistentCalls:
          m_Calls: []
      onLineEnd:
        m_PersistentCalls:
          m_Calls: []
    - text: You want to join our crew?
      onLineStart:
        m_PersistentCalls:
          m_Calls: []
      onLineEnd:
        m_PersistentCalls:
          m_Calls: []
    - text: AHAHAHAHAHAHAHAHAHAHAHAH
      onLineStart:
        m_PersistentCalls:
          m_Calls: []
      onLineEnd:
        m_PersistentCalls:
          m_Calls: []
    - text: Alright, fight my men to prove you are worthy!
      onLineStart:
        m_PersistentCalls:
          m_Calls: []
      onLineEnd:
        m_PersistentCalls:
          m_Calls: []
    lines:
    - Hey you! Who let you in here?
    - You want to join our crew?
    - AHAHAHAHAHAHAHAHAHAHAHAH
    - Alright, fight my men to prove you are worthy!
  - dialogueLines:
    - text: You landlubbers! That girl kicked your asses!
      onLineStart:
        m_PersistentCalls:
          m_Calls: []
      onLineEnd:
        m_PersistentCalls:
          m_Calls: []
    - text: Alright, seems you can be usefull, get on board!
      onLineStart:
        m_PersistentCalls:
          m_Calls: []
      onLineEnd:
        m_PersistentCalls:
          m_Calls: []
    - text: Hear me lads! We sail now!
      onLineStart:
        m_PersistentCalls:
          m_Calls: []
      onLineEnd:
        m_PersistentCalls:
          m_Calls: []
    lines:
    - You landlubbers! That girl kicked your asses!
    - Alright, seems you can be usefull, get on board!
    - Hear me lads! We sail now!
  - dialogueLines:
    - text: I can't let you in, captain won't be glad
      onLineStart:
        m_PersistentCalls:
          m_Calls: []
      onLineEnd:
        m_PersistentCalls:
          m_Calls: []
    - text: 'But if you will prove that you can be usefull I can change my mind '
      onLineStart:
        m_PersistentCalls:
          m_Calls: []
      onLineEnd:
        m_PersistentCalls:
          m_Calls: []
    - text: Find my pistol, I lost it somewere on the pierce. .
      onLineStart:
        m_PersistentCalls:
          m_Calls: []
      onLineEnd:
        m_PersistentCalls:
          m_Calls: []
    - text: May be it fell in water..
      onLineStart:
        m_PersistentCalls:
          m_Calls: []
      onLineEnd:
        m_PersistentCalls:
          m_Calls: []
    lines:
    - I can't let you in, captain won't be glad
    - 'But if you will prove that you can be usefull I can change my mind '
    - Find my pistol, I lost it somewere on the pierce. .
    - May be it fell in water..
  - dialogueLines:
    - text: 'Wow you find my pistol! '
      onLineStart:
        m_PersistentCalls:
          m_Calls: []
      onLineEnd:
        m_PersistentCalls:
          m_Calls: []
    - text: 'May be you are not so useless after all... '
      onLineStart:
        m_PersistentCalls:
          m_Calls: []
      onLineEnd:
        m_PersistentCalls:
          m_Calls: []
    - text: Go ahead and talk to our captain, he will decide if you can get on board.
      onLineStart:
        m_PersistentCalls:
          m_Calls: []
      onLineEnd:
        m_PersistentCalls:
          m_Calls: []
    lines:
    - 'Wow you find my pistol! '
    - 'May be you are not so useless after all... '
    - Go ahead and talk to our captain, he will decide if you can get on board.
  - dialogueLines:
    - text: ' Mary, you''re finally awake! '
      onLineStart:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1648568938}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 1
            m_CallState: 2
      onLineEnd:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 0}
            m_TargetAssemblyTypeName: 
            m_MethodName: 
            m_Mode: 0
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: 
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
    - text: How badly have you been hurt by this vile sorcerer...
      onLineStart:
        m_PersistentCalls:
          m_Calls: []
      onLineEnd:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1648568938}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
    - text: Everything is fine. I've recovered and I have to go save my brother.
      onLineStart:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1886242557}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 1
            m_CallState: 2
      onLineEnd:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1886242557}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
    - text: And how are you going to resist him?
      onLineStart:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1648568938}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 1
            m_CallState: 2
      onLineEnd:
        m_PersistentCalls:
          m_Calls: []
    - text: You saw that physical abilities are nothing against their magic
      onLineStart:
        m_PersistentCalls:
          m_Calls: []
      onLineEnd:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1648568938}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
    - text: ' So I''ll go to that wizard on the island and persuade him to teach
        me magic!'
      onLineStart:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1886242557}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 1
            m_CallState: 2
      onLineEnd:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1886242557}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
    - text: I understand that it's pointless to stop you, so I just wish you luck.
      onLineStart:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1648568938}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 1
            m_CallState: 2
      onLineEnd:
        m_PersistentCalls:
          m_Calls: []
    - text: Take care of yourself
      onLineStart:
        m_PersistentCalls:
          m_Calls: []
      onLineEnd:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1648568938}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
    lines:
    - Mary! I should tell you something about your true family
    - I found you when you was just a little girl, in a burned village
    - But now I think you have a chance to find your family
    - One of the drunk pirates told about a wizard that knows every thing, you should
      find him!
    - Find a way to get on their ship!
    - Be carefull my dear, wish you luck!
  - dialogueLines:
    - text: Hey, take me to your captain!
      onLineStart:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1886242557}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 1
            m_CallState: 2
      onLineEnd:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1886242557}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
    - text: What? Who else are you, and why do you need a captain?
      onLineStart:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1307288191}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 1
            m_CallState: 2
      onLineEnd:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1307288191}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
    - text: You have to take me to the wizard's island!
      onLineStart:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1886242557}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 1
            m_CallState: 2
      onLineEnd:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1886242557}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
    - text: Ha! What else! Now I'm going to teach you a lesson!
      onLineStart:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1307288191}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 1
            m_CallState: 2
      onLineEnd:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1307288191}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
    - text: Apparently we will have to break through with a fight
      onLineStart:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1886242557}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 1
            m_CallState: 2
      onLineEnd:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1553781258}
            m_TargetAssemblyTypeName: AI.GroundMeleeEnemy, Assembly-CSharp
            m_MethodName: StartBehavior
            m_Mode: 1
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
          - m_Target: {fileID: 1886242557}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
    lines: []
