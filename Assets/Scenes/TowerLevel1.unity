--- !u!114 &2088760829
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2088760827}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7b9f966cbd6145439b4e401d06d75d46, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogLines:
  - dialogueLines:
    - text: ' Ummm. '
      onLineStart:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1594046025}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 1
            m_CallState: 2
      onLineEnd:
        m_PersistentCalls:
          m_Calls: []
    - text: 'It seemed to me that the tower is quite small, but inside it is just
        huge! '
      onLineStart:
        m_PersistentCalls:
          m_Calls: []
      onLineEnd:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1594046025}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
    - text: Well, all wizard towers are like that.
      onLineStart:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 880540511}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 1
            m_CallState: 2
      onLineEnd:
        m_PersistentCalls:
          m_Calls: []
    - text: You don't seem to know anything about magic at all?
      onLineStart:
        m_PersistentCalls:
          m_Calls: []
      onLineEnd:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 880540511}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
    - text: Well, I know that without magic I can't defeat demons and save the world
      onLineStart:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1594046025}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 1
            m_CallState: 2
      onLineEnd:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1594046025}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
    lines: []
  - dialogueLines:
    - text: 'Alright, let me see... '
      onLineStart:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 880540511}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 1
            m_CallState: 2
      onLineEnd:
        m_PersistentCalls:
          m_Calls: []
    - text: Were did I put it...
      onLineStart:
        m_PersistentCalls:
          m_Calls: []
      onLineEnd:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 880540511}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
    lines: []
  - dialogueLines:
    - text: Go to the tribune
      onLineStart:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 880540511}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 1
            m_CallState: 2
      onLineEnd:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 880540511}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
          - m_Target: {fileID: 1713033319}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 1
            m_CallState: 2
    lines: []
  - dialogueLines:
    - text: Wait, what are you doing?!
      onLineStart:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1594046025}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 1
            m_CallState: 2
      onLineEnd:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1594046025}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
    - text: You'd better stay still!
      onLineStart:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 880540511}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 1
            m_CallState: 2
      onLineEnd:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 880540511}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
    lines: []
  - dialogueLines:
    - text: AHHH! I'm on fire!
      onLineStart:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 1594046025}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
