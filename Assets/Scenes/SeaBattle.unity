    - target: {fileID: 2406992749507461194, guid: 9ebdd227594542a4497eea67b7cdd6f7, type: 3}
      propertyPath: dialogLines.Array.data[2].lines.Array.size
      value: 3
      objectReference: {fileID: 0}
    - target: {fileID: 2406992749507461194, guid: 9ebdd227594542a4497eea67b7cdd6f7, type: 3}
      propertyPath: 'dialogLines.Array.data[0].lines.Array.data[0]'
      value: Hey you! Who let you in here?
      objectReference: {fileID: 0}
    - target: {fileID: 2406992749507461194, guid: 9ebdd227594542a4497eea67b7cdd6f7, type: 3}
      propertyPath: 'dialogLines.Array.data[0].lines.Array.data[1]'
      value: You want to joint our crew?
      objectReference: {fileID: 0}
    - target: {fileID: 2406992749507461194, guid: 9ebdd227594542a4497eea67b7cdd6f7, type: 3}
      propertyPath: 'dialogLines.Array.data[0].lines.Array.data[2]'
      value: AHAHAHAHAHAHAHAHAHAHAHAH
      objectReference: {fileID: 0}
    - target: {fileID: 2406992749507461194, guid: 9ebdd227594542a4497eea67b7cdd6f7, type: 3}
      propertyPath: 'dialogLines.Array.data[0].lines.Array.data[3]'
      value: Alright, fight my men to proove you are worthy!
      objectReference: {fileID: 0}
    - target: {fileID: 2406992749507461194, guid: 9ebdd227594542a4497eea67b7cdd6f7, type: 3}
      propertyPath: 'dialogLines.Array.data[1].lines.Array.data[0]'
      value: You landlubbers! That girl kicked you asses!
      objectReference: {fileID: 0}
    - target: {fileID: 2406992749507461194, guid: 9ebdd227594542a4497eea67b7cdd6f7, type: 3}
      propertyPath: 'dialogLines.Array.data[1].lines.Array.data[1]'
      value: Alright, seems you can be usefull, get on board!
      objectReference: {fileID: 0}
    - target: {fileID: 2406992749507461194, guid: 9ebdd227594542a4497eea67b7cdd6f7, type: 3}
      propertyPath: 'dialogLines.Array.data[1].lines.Array.data[2]'
      value: Hear me lads! We sail now!
      objectReference: {fileID: 0}
    - target: {fileID: 2406992749507461194, guid: 9ebdd227594542a4497eea67b7cdd6f7, type: 3}
      propertyPath: 'dialogLines.Array.data[2].lines.Array.data[0]'
      value: Hurry we should leave before the sea king appears!
      objectReference: {fileID: 0}
    - target: {fileID: 2406992749507461194, guid: 9ebdd227594542a4497eea67b7cdd6f7, type: 3}
      propertyPath: 'dialogLines.Array.data[2].lines.Array.data[1]'
      value: OH NO ITS HERE
      objectReference: {fileID: 0}
    - target: {fileID: 2406992749507461194, guid: 9ebdd227594542a4497eea67b7cdd6f7, type: 3}
      propertyPath: 'dialogLines.Array.data[2].lines.Array.data[2]'
      value: LORD SAVE OUR SOULS
      objectReference: {fileID: 0}
    - target: {fileID: 2406992749507461194, guid: 9ebdd227594542a4497eea67b7cdd6f7, type: 3}
